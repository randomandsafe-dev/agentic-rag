# OpenAI 或任何 OpenAI 兼容服务的密钥
OPENAI_API_KEY=your_api_key_here

# 可选：使用兼容服务时填写，例如 https://api.example.com/v1
# OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# DeepSeek 等仅提供聊天模型的服务，请保持 local（默认）。首次入库会下载本地中文向量模型。
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# 仅当你的服务明确提供 /embeddings 接口时，改为 openai 并填写对应模型：
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# 检索配置
RAG_TOP_K=4

# 检索增强配置（查询改写 + 相关性判断 + 重试）
REWRITE_ENABLED=true              # 是否启用查询改写
RELEVANCE_JUDGE_ENABLED=true      # 是否启用相关性判断
RELEVANCE_STRATEGY=llm            # 判断策略: llm(大模型语义判断) | vector(向量分数) | hybrid(向量初筛+LLM终判)
MAX_RETRIES=2                     # 最大重试次数
RELEVANCE_THRESHOLD=2             # 相关性阈值 0-3（>=此值视为相关）
# REWRITE_MODEL=gpt-4o-mini      # 可选：改写/判断专用模型（不设则用主模型）
